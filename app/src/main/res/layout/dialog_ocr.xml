<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_glass_panel"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OCR - Reconhecimento de Texto"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnRecognize"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="Reconhecer Região"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_tool"
        android:layout_marginBottom="12dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/ocrResultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nenhum texto reconhecido ainda."
            android:textSize="14sp"
            android:textColor="#CCCCCC"
            android:padding="8dp"
            android:background="#1E1E1E" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCopy"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Copiar"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:background="@drawable/btn_tool"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnCreateFlashcard"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Criar Flashcard"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:background="@drawable/btn_tool" />
    </LinearLayout>

</LinearLayout>
