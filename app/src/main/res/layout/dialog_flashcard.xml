<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_glass_panel"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Flashcards"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <!-- Card display -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="#1E1E1E"
        android:padding="16dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/cardText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:gravity="center" />
    </FrameLayout>

    <TextView
        android:id="@+id/cardCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0 / 0"
        android:textColor="#888888"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnFlip"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:text="Virar"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_tool"
        android:layout_marginBottom="8dp" />

    <!-- Review buttons -->
    <LinearLayout
        android:id="@+id/reviewButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btnAgain"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="De novo"
            android:textColor="#FF5252"
            android:textSize="11sp"
            android:background="@drawable/btn_tool"
            android:layout_marginEnd="2dp" />

        <Button
            android:id="@+id/btnHard"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Difícil"
            android:textColor="#FF9100"
            android:textSize="11sp"
            android:background="@drawable/btn_tool"
            android:layout_marginEnd="2dp" />

        <Button
            android:id="@+id/btnGood"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Bom"
            android:textColor="#00E676"
            android:textSize="11sp"
            android:background="@drawable/btn_tool"
            android:layout_marginEnd="2dp" />

        <Button
            android:id="@+id/btnEasy"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Fácil"
            android:textColor="#00B0FF"
            android:textSize="11sp"
            android:background="@drawable/btn_tool" />
    </LinearLayout>

    <!-- Create new card -->
    <Button
        android:id="@+id/btnCreate"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:text="+ Novo Flashcard"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_tool"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:id="@+id/createSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <EditText
            android:id="@+id/inputFront"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:hint="Frente"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:textSize="13sp"
            android:background="#1E1E1E"
            android:padding="8dp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/inputBack"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:hint="Verso"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:textSize="13sp"
            android:background="#1E1E1E"
            android:padding="8dp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/inputTags"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:hint="Tags (separadas por vírgula)"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:textSize="13sp"
            android:background="#1E1E1E"
            android:padding="8dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnSaveCard"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="Salvar"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_tool" />
    </LinearLayout>

</LinearLayout>
